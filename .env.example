# Pharos ProofPay — Environment Configuration Template
# Copy this file to '.env' and fill in your own values. Never commit '.env' to git.

# Your wallet private key (do not include 0x prefix)
PRIVATE_KEY=your_private_key_here

# Deployed InvoiceLogger contract address on Pharos Atlantic Testnet
CONTRACT=your_deployed_contract_address_here

# Pharos Atlantic Testnet RPC
RPC_URL=https://atlantic.dplabs-internal.com

